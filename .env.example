# ─── Monad testnet ───────────────────────────────────────────────
RPC_URL=https://testnet-rpc.monad.xyz
CHAIN_ID=10143
EXPLORER_URL=https://monad-testnet.socialscan.io

# ─── Wallets (custodial) ─────────────────────────────────────────
# Generated by `npm run setup` (in blockchain/). Faucet the deployer with
# MON; it deploys the QuestFactory. Faucet the quest master with enough MON
# to escrow rewards + gas, and the players with a little MON for gas.
DEPLOYER_PK=0x...

# One key per agent — env name is AGENT_<ID uppercased>_PK
AGENT_QUESTMASTER_PK=0x...
AGENT_ARIA_PK=0x...
AGENT_KAI_PK=0x...

# Written by the QuestFactory deploy script; also copy into agent-backend/keys.json
QUEST_FACTORY_ADDRESS=0x...
