# OS
.DS_Store

# World data (regenerates on first boot; commit a snapshot zip if you want to share)
data/world/
data/world_nether/
data/world_the_end/
data/world.bak.*/

# Runtime / generated by Paper
data/cache/
data/libraries/
data/versions/
data/logs/
data/crash-reports/
data/debug/
data/.console_history

# Player / op state — machine-specific
data/banned-ips.json
data/banned-players.json
data/ops.json
data/whitelist.json
data/usercache.json
data/version_history.json

# server.properties is regenerated each boot from docker-compose env vars
data/server.properties

# itzg image internal state (includes generated rcon password)
data/.rcon-cli.env
data/.rcon-cli.yaml
data/.paper.env
data/.modrinth-manifest.json
data/.papermc-manifest.json

# Plugin-generated data (configs are kept; runtime data/databases are not)
data/plugins/*/cache/
data/plugins/*/logs/
data/plugins/.paper-remapped/
data/plugins/bStats/
data/plugins/spark/tmp-client/

# Keep .jar files (Paper server jar + plugin jars) — explicitly not ignored
!*.jar
